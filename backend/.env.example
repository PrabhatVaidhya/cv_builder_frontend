# Server Configuration
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/cv-generator

# Google Gemini API Key
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Instructions:
# 1. Replace 'your_gemini_api_key_here' with your actual Gemini API key
# 2. For MongoDB, you can use the local URI above or a cloud MongoDB Atlas URI
# 3. Restart the backend server after making changes
